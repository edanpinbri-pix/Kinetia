<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
  ExtensionBundleId="com.kinetia.panel"
  ExtensionBundleVersion="2.0.0"
  Version="10.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.kinetia.panel.main" Version="2.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- After Effects 2022 (v22) and above -->
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="10.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.kinetia.panel.main">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/kinetia.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Kinetia</Menu>
          <Geometry>
            <Size>
              <Height>620</Height>
              <Width>300</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>240</Width>
            </MinSize>
          </Geometry>
          <Icons/>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
